                </div>

                <div className="flex-grow overflow-y-auto p-5 space-y-4 scrollbar-hide">
                   {chatMessages.map(m => (
                     <div key={m.id} className={`flex ${m.sender === 'user' ? 'justify-end' : 'justify-start'}`}>
