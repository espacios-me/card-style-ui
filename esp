/* ─── PILL TAG ───────────────────────────────────────────────────────── */
function Pill({ hex, hx2, label }) {
  return (
    <span style={{
      display: 'inline-flex', alignItems: 'center', gap: 5,
      padding: '3px 10px 3px 7px', borderRadius: 20,
      fontSize: 9, fontWeight: 800, letterSpacing: '0.1em', textTransform: 'uppercase',
      background: hex + '18', border: `1px solid ${hex}35`, color: hex,
    }}>
      <span style={{ width: 6, height: 6, borderRadius: '50%', background: `linear-gradient(135deg, ${hex}, ${hx2})`, display: 'inline-block', flexShrink: 0 }} />
      {label}
    </span>
  );
