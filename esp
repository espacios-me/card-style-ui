  ]);
  const [chatInput, setChatInput] = useState('');

  const searchInputRef = useRef(null);
  const assistantContainerRef = useRef(null);

  useEffect(() => {
    signInAnonymously(auth);
    const unsubscribe = onAuthStateChanged(auth, (u) => {
      setUser(u);
      setData(fetchMasterData());
    });
    return () => unsubscribe();
  }, []);

  // Handle clicking outside the chat bubble to close it
  useEffect(() => {
    const handleClickOutside = (event) => {
      if (assistantContainerRef.current && !assistantContainerRef.current.contains(event.target)) {
        setAssistantActive(false);
      }
    };
    if (assistantActive) {
      document.addEventListener('mousedown', handleClickOutside);
    }
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, [assistantActive]);

  const handleRipple = (e) => {
    e.stopPropagation();
    const rect = e.currentTarget.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const y = e.clientY - rect.top;
    setRipples(prev => [...prev, { x, y, id: Date.now() }]);
    setTimeout(() => setRipples(prev => prev.slice(1)), 800);
    
    setAssistantActive(!assistantActive);
    if (!assistantActive) {
      setTimeout(() => searchInputRef.current?.focus(), 200);
    }
  };

  const handleChatSend = (e) => {
    e.preventDefault();
    if (!chatInput.trim()) return;
    const newMsg = { id: Date.now(), text: chatInput, sender: 'user' };
    setChatMessages([...chatMessages, newMsg]);
    setChatInput('');
    
    setTimeout(() => {
      setChatMessages(prev => [...prev, { 
        id: Date.now() + 1, 
        text: `Processing query for "${chatInput}"... Analyzing 547 registries for optimization.`, 
        sender: 'ai' 
      }]);
    }, 800);
  };

