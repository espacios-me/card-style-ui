/* ─── MAIN EXPORT ────────────────────────────────────────────────────── */
export default function App() {
  const [selected, setSelected] = useState(null);
  const [saved, setSaved] = useState(new Set());
  const [filter, setFilter] = useState('all');

  const toggleSave = (id) =>
    setSaved((prev) => { const n = new Set(prev); n.has(id) ? n.delete(id) : n.add(id); return n; });

  const filtered = useMemo(
    () => filter === 'all' ? projects : projects.filter((p) => priceTag(toNum(p.price)).key === filter),
    [filter]
  );

  // Prevent body scroll when detail is open
  useEffect(() => {
    document.body.style.overflow = selected ? 'hidden' : '';
    return () => { document.body.style.overflow = ''; };
  }, [selected]);

  return (
    <div style={{ minHeight: '100vh', background: '#05050f', color: '#fff', fontFamily: 'system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif', position: 'relative' }}>
      <style>{`
        .masonry-grid {
          column-count: 2;
          column-gap: 12px;
        }
        @media (min-width: 640px) {
          .masonry-grid { column-count: 3; column-gap: 16px; }
        }
        @media (min-width: 1024px) {
          .masonry-grid { column-count: 4; }
        }
        @media (min-width: 1280px) {
          .masonry-grid { column-count: 5; }
        }
      `}</style>
      <Orbs />

      {/* Sticky header */}
      <header style={{
        position: 'sticky', top: 0, zIndex: 100,
        background: 'rgba(5,5,15,0.82)', backdropFilter: 'blur(28px)', WebkitBackdropFilter: 'blur(28px)',
        borderBottom: '1px solid rgba(255,255,255,0.06)',
        padding: '13px 20px',
        display: 'flex', alignItems: 'center', gap: 16,
      }}>
        {/* Branding */}
        <div style={{ flexShrink: 0 }}>
          <div style={{ fontSize: 8, fontWeight: 800, letterSpacing: '0.26em', textTransform: 'uppercase', color: 'rgba(255,255,255,0.22)' }}>
            Dubai Portfolio
          </div>
          <h1 style={{ fontSize: 16, fontWeight: 700, letterSpacing: '-0.02em', margin: 0 }}>
            {AGENT}
          </h1>
        </div>

        <div style={{ width: 1, height: 28, background: 'rgba(255,255,255,0.08)', flexShrink: 0 }} />

        {/* Filter pills */}
        <div style={{ display: 'flex', gap: 6, overflowX: 'auto', scrollbarWidth: 'none', flex: 1, paddingBottom: 1 }}>
          {FILTERS.map((f) => {
            const active = filter === f.key;
            return (
              <button key={f.key} onClick={() => setFilter(f.key)} style={{
                flexShrink: 0, padding: '5px 13px', borderRadius: 20,
                fontSize: 9, fontWeight: 800, letterSpacing: '0.07em', textTransform: 'uppercase',
                background: active ? f.hex + '1c' : 'rgba(255,255,255,0.04)',
                border: active ? `1px solid ${f.hex}40` : '1px solid rgba(255,255,255,0.07)',
                color: active ? f.hex : 'rgba(255,255,255,0.3)', cursor: 'pointer',
                transition: 'all 0.2s ease',
              }}>{f.label}</button>
            );
          })}
        </div>

        {/* Saved count */}
        {saved.size > 0 && (
          <div style={{
            flexShrink: 0, display: 'flex', alignItems: 'center', gap: 6,
            padding: '5px 12px', borderRadius: 20,
            background: 'rgba(248,113,113,0.1)', border: '1px solid rgba(248,113,113,0.25)',
            fontSize: 10, fontWeight: 800, color: '#f87171',
          }}>
            <Bookmark size={11} />
            {saved.size}
          </div>
        )}

        {/* WhatsApp */}
        <a href={`https://wa.me/${PHONE}`} target="_blank" rel="noreferrer" style={{
          flexShrink: 0, display: 'flex', alignItems: 'center', gap: 7,
          padding: '6px 14px', borderRadius: 20,
          background: 'rgba(255,255,255,0.07)', border: '1px solid rgba(255,255,255,0.12)',
          fontSize: 10, fontWeight: 800, letterSpacing: '0.06em', textTransform: 'uppercase',
          color: '#fff', textDecoration: 'none',
        }}>
          <MessageCircle size={11} /> WhatsApp
        </a>
      </header>

      {/* Board section header */}
      <div style={{ padding: '24px 16px 4px', position: 'relative', zIndex: 10 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 10, marginBottom: 4 }}>
          <SlidersHorizontal size={12} style={{ color: 'rgba(255,255,255,0.25)' }} />
          <span style={{ fontSize: 9, fontWeight: 800, letterSpacing: '0.22em', textTransform: 'uppercase', color: 'rgba(255,255,255,0.22)' }}>
            {filtered.length} {filtered.length === 1 ? 'Property' : 'Properties'} · Tap to explore
          </span>
        </div>
      </div>

      {/* Masonry grid */}
      <div style={{ padding: '12px 16px 40px', position: 'relative', zIndex: 10 }}>
        <div className="masonry-grid">
          {filtered.map((p, idx) => (
            <PinCard
              key={p.id}
              project={p}
              index={projects.indexOf(p)}
              onClick={() => setSelected(p)}
              saved={saved.has(p.id)}
              onSave={() => toggleSave(p.id)}
            />
          ))}
        </div>

        {filtered.length === 0 && (
          <div style={{ textAlign: 'center', padding: '80px 20px', color: 'rgba(255,255,255,0.18)' }}>
            <TrendingUp size={34} style={{ margin: '0 auto 14px', opacity: 0.25, display: 'block' }} />
            <p style={{ fontSize: 15, fontWeight: 700 }}>No properties in this range</p>
          </div>
        )}
      </div>

      {/* Slide-over Detail Drawer */}
      {selected && (
        <DetailCard project={selected} onClose={() => setSelected(null)} onSelect={setSelected} />
      )}
    </div>
  );
}
