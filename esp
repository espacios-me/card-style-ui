/* ─── HELPERS ─────────────────────────────────────────────────────────── */
const toNum = (s) => parseFloat((s || '').replace(/[^0-9.]/g, '')) || 0;

const priceTag = (n) => {
  if (n < 5) return { key: 'entry', label: '< AED 5M', hex: '#5eead4', hx2: '#22d3ee' };
  if (n < 15) return { key: 'mid', label: 'AED 5–15M', hex: '#a78bfa', hx2: '#818cf8' };
  if (n < 30) return { key: 'premium', label: 'AED 15–30M', hex: '#f0abfc', hx2: '#e879f9' };
  return { key: 'ultra', label: 'AED 30M+', hex: '#fcd34d', hx2: '#fb923c' };
};

const getSimilar = (p, n = 3) => {
  const target = toNum(p.price);
  const tag = priceTag(target).key;
  let pool = projects.filter((x) => x.id !== p.id && priceTag(toNum(x.price)).key === tag);
  if (pool.length < n) pool = projects.filter((x) => x.id !== p.id);
  return pool.sort((a, b) => Math.abs(toNum(a.price) - target) - Math.abs(toNum(b.price) - target)).slice(0, n);
};

